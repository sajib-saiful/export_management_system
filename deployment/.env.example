POSTGRES_DB=ems_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_API_BASE_URL=http://localhost:8000

# Remote access (open UI from another PC):
# - Set VITE_API_BASE_URL to your server machine IP/hostname, e.g. http://<SERVER_LAN_IP>:8000
# - Add that same origin to CORS_ORIGINS, e.g. http://<SERVER_LAN_IP>:5173
